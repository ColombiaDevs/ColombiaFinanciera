---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/sections/Header.astro";
import Footer from "../components/sections/Footer.astro";
---

<!doctype html>
<html lang="es" data-theme="dark" class="dark">
  <head>
    <BaseHead
      title="Contribuidores - ColombiaFinanciera"
      description="Como participar, proponer mejoras y contribuir al proyecto."
    />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-5xl px-4 py-12 md:py-14 space-y-8">
      <section class="space-y-2 max-readable card-surface p-5 md:p-6">
        <h1 class="text-3xl md:text-4xl font-semibold text-accent">
          Contribuidores
        </h1>
        <p class="text-secondary">Proyecto mantenido por la comunidad.</p>
      </section>

      <section class="space-y-3 max-readable card-surface p-5 md:p-6">
        <p class="text-sm md:text-base text-secondary">
          Proyecto abierto. Contribuciones bienvenidas.
        </p>
        <p class="text-sm md:text-base text-secondary">
          Abrir issues, proponer mejoras y enviar pull requests pequeñas es
          suficiente para empezar.
        </p>
        <a
          href="https://github.com/ColombiaDevs/ColombiaFinanciera"
          target="_blank"
          rel="noopener noreferrer"
          class="sw-btn inline-flex w-fit items-center gap-2">Ver GitHub</a
        >
      </section>
    </main>
    <Footer />
  </body>
</html>
