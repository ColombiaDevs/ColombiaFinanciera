---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate)
  .slice(0, 4);
---

<!doctype html>
<html lang="es" data-theme="dark" class="dark">
  <head>
    <BaseHead
      title="ColombiaFinanciera"
      description="Artículos financieros simples para aprender y conversar en comunidad."
    />
  </head>
  <body>
    <Header />
    <main>
      <HeroSection
        title="No es tan claro qué hacer con tu dinero en Colombia."
        subtitle="Artículos introductorios basados en discusiones reales de la comunidad."
        showCTA
        primaryCTA={{
          text: "Ver discusiones reales",
          href: "https://reddit.com/r/colombiafinanciera",
        }}
        decisionPrompt="¿Qué estás intentando hacer?"
        decisionOptions={[
          { text: "↑ Aumentar ahorro", href: "/blog/tag/ahorro/" },
          { text: "↓ Reducir deuda", href: "/blog/tag/deuda/" },
          { text: "→ Empezar a invertir", href: "/blog/tag/inversion/" },
        ]}
      />

      <section class="py-8 md:py-10">
        <div
          class="mx-auto max-w-5xl px-4 space-y-5 text-left card-surface p-5 md:p-6"
        >
          <h2 class="text-2xl md:text-3xl font-semibold text-foreground">
            Artículos recientes
          </h2>
          <div class="space-y-4">
            {
              recentPosts.map((post) => (
                <article class="border-t border-subtle pt-4 first:border-t-0 first:pt-0">
                  <a href={`/blog/${post.id}/`} class="no-underline group">
                    <h3 class="text-lg md:text-xl font-medium text-primary hover-text-accent">
                      {post.data.title}
                    </h3>
                    <p class="mt-1 max-copy-narrow text-secondary leading-relaxed">
                      {post.data.description}
                    </p>
                    <div class="mt-2 text-sm text-muted">
                      <FormattedDate date={post.data.pubDate} />
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="py-6 md:py-8">
        <div
          class="mx-auto max-w-5xl px-4 space-y-2 text-center md:text-left card-surface p-5 md:p-6 md:max-panel"
        >
          <h2 class="text-xl md:text-2xl font-medium text-accent">
            Herramientas
          </h2>
          <p
            class="text-sm md:text-base text-secondary max-compact md:mx-0 mx-auto"
          >
            Herramientas en desarrollo.
          </p>
        </div>
      </section>

      <section class="py-6 md:py-8">
        <div
          class="mx-auto max-w-5xl px-4 space-y-2 text-left md:text-right md:ml-auto card-surface p-5 md:p-6 md:max-panel"
        >
          <h2 class="text-xl md:text-2xl font-medium text-foreground">
            Contribuidores
          </h2>
          <p class="text-sm md:text-base text-secondary max-compact md:ml-auto">
            Proyecto abierto. Contribuciones bienvenidas.
          </p>
          <a
            href="/contribuidores"
            class="sw-btn-sm inline-flex w-fit items-center gap-2 text-sm md:ml-auto"
            >Ver cómo participar</a
          >
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
