---
import Button from "../ui/button/Button.astro";
interface Cta {
  text: string;
  href: string;
}

interface Props {
  title: string;
  subtitle?: string;
  showCTA?: boolean;
  primaryCTA?: Cta;
  secondaryCTA?: Cta;
  decisionPrompt?: string;
  decisionOptions?: Cta[];
}

const {
  title,
  subtitle,
  showCTA = false,
  primaryCTA,
  secondaryCTA,
  decisionPrompt,
  decisionOptions = [],
} = Astro.props as Props;
---

<section class="w-full py-10 md:py-12">
  <div class="mx-auto max-readable px-4 text-center">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-foreground">
      <span class="text-foreground">{title}</span>
    </h1>
    {
      subtitle && (
        <p class="mt-4 text-base md:text-xl text-secondary max-copy mx-auto">
          {subtitle}
        </p>
      )
    }
    {
      showCTA && (primaryCTA || secondaryCTA) && (
        <div class="mt-7 flex flex-col sm:flex-row items-center justify-center gap-3">
          {primaryCTA && (
            <Button href={primaryCTA.href} variant="primary" size="lg">
              {primaryCTA.text}
            </Button>
          )}
          {secondaryCTA && (
            <Button href={secondaryCTA.href} variant="secondary" size="md">
              {secondaryCTA.text}
            </Button>
          )}
        </div>
      )
    }
    {
      decisionPrompt && decisionOptions.length > 0 && (
        <div class="mt-8 mx-auto max-decision text-left border-t border-subtle pt-5">
          <p class="text-sm md:text-base font-medium text-primary">
            {decisionPrompt}
          </p>
          <div class="mt-3 flex flex-col">
            {decisionOptions.map((option) => (
              <a
                href={option.href}
                class="group decision-link flex items-center justify-between gap-4 border-t border-subtle py-3 font-medium text-secondary no-underline hover-text-accent"
              >
                <span>{option.text}</span>
                <span
                  class="text-accent opacity-0 transition-none group-hover:opacity-100"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
