---
import Button from '../ui/button/Button.astro';
interface Cta {
  text: string;
  href: string;
}

interface Props {
  title: string;
  subtitle?: string;
  showCTA?: boolean;
  primaryCTA?: Cta;
  secondaryCTA?: Cta;
  decisionPrompt?: string;
  decisionOptions?: Cta[];
}

const {
  title,
  subtitle,
  showCTA = false,
  primaryCTA,
  secondaryCTA,
  decisionPrompt,
  decisionOptions = [],
} = Astro.props as Props;
---

<section class="w-full py-8 md:py-10">
  <div class="max-readable mx-auto px-4 text-center">
    <h1 class="text-foreground text-5xl font-bold tracking-tight md:text-7xl">
      <span class="text-foreground">{title}</span>
    </h1>
    {
      subtitle && (
        <p class="text-secondary max-copy mx-auto mt-4 text-base md:text-xl">{subtitle}</p>
      )
    }
    {
      showCTA && (primaryCTA || secondaryCTA) && (
        <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
          {primaryCTA && (
            <Button href={primaryCTA.href} variant="primary" size="lg">
              {primaryCTA.text}
            </Button>
          )}
          {secondaryCTA && (
            <Button href={secondaryCTA.href} variant="secondary" size="md">
              {secondaryCTA.text}
            </Button>
          )}
        </div>
      )
    }
    {
      decisionPrompt && decisionOptions.length > 0 && (
        <div class="max-decision border-subtle-soft mx-auto mt-8 border-t pt-5 text-left">
          <p class="text-primary text-sm font-medium md:text-base">{decisionPrompt}</p>
          <p class="text-secondary mt-1 text-sm">Puedes empezar por aquí:</p>
          <div class="mt-3 flex flex-col">
            {decisionOptions.map((option) => (
              <a
                href={option.href}
                class="group decision-link border-subtle-soft text-secondary hover-text-accent flex items-center justify-between gap-4 border-t py-3 font-medium no-underline"
              >
                <span>{option.text}</span>
                <span
                  class="text-accent opacity-0 transition-none group-hover:opacity-100"
                  aria-hidden="true"
                >
                  →
                </span>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
