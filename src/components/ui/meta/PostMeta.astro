---
import { getAuthor } from '../../../data/author';
import FormattedDate from '../../FormattedDate.astro';
import { slugifyTag as slugify } from '../../../lib/slug';

interface Props {
  pubDate: Date;
  readingTimeMin: number;
  authorId?: string;
  source?: {
    subreddit: string;
    threads: string[];
    originalAuthor?: string;
  };
}
const { pubDate, readingTimeMin, authorId, source } = Astro.props as Props;
const author = getAuthor(authorId ?? '');
const authorSlug = slugify(authorId || 'ColombiaFinanciera');
---

<div class="sw-post-meta flex items-start justify-between gap-4 py-2">
  <div class="flex items-start gap-3">
    <div class="border-subtle h-12 w-12 overflow-hidden rounded-full border">
      <img
        src={author?.avatar || '/images/avatar.png'}
        alt={author?.name || 'Autor'}
        width="48"
        height="48"
        loading="lazy"
        class="h-full w-full object-cover"
      />
    </div>
    <div class="flex flex-col">
      <p class="text-primary text-sm font-semibold">
        Autor:
        <a href={`/blog/author/${authorSlug}/`} class="interactive-link"
          >{author?.name || 'Autor'}</a
        >
      </p>
      <div class="text-muted flex items-center gap-3 text-xs">
        <div class="flex items-center gap-1">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"
            ><path
              fill="currentColor"
              d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"
            ></path></svg
          >
          <FormattedDate date={pubDate} />
        </div>
        <div class="flex items-center gap-1">
          <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
            <path
              fill="currentColor"
              d="M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20Zm0-18a8 8 0 1 0 0 16 8 8 0 0 0 0-16Zm1 9h3v-2h-2V7h-2v6Z"
            ></path>
          </svg>
          <span>{readingTimeMin} min lectura</span>
        </div>
      </div>
      {
        source && (
          <p class="text-muted mt-1 text-xs">
            Basado en discusiones de {source.subreddit}
            {source.originalAuthor && ` · Idea original: ${source.originalAuthor}`}
          </p>
        )
      }
      {
        (author?.reddit || author?.github) && (
          <p class="text-muted mt-1 flex items-center gap-3 text-xs">
            {author?.reddit && (
              <a
                href={author.reddit}
                target="_blank"
                rel="noopener noreferrer"
                class="interactive-link text-xs"
              >
                Reddit
              </a>
            )}
            {author?.github && (
              <a
                href={author.github}
                target="_blank"
                rel="noopener noreferrer"
                class="interactive-link text-xs"
              >
                GitHub
              </a>
            )}
          </p>
        )
      }
    </div>
  </div>
</div>
